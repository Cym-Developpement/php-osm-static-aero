{
  "name": "ycdev/php-osm-static-aero",
  "type": "library",
  "description": "PHP library to generate static aeronautical maps from OpenStreetMap (OSM) with markers, lines and drawings.",
  "keywords": [
    "php",
    "osm",
    "openstreetmap",
    "map",
    "static",
    "image",
    "aeronautical",
    "aviation"
  ],
  "homepage": "https://github.com/ycdev/php-osm-static-aero",
  "license": "MIT",
  "authors": [
    {
      "name": "Franck ALARY",
      "homepage": "https://github.com/DantSu",
      "role": "Original Developer"
    }
  ],
  "require": {
    "php": ">=7.0",
    "ext-gd": "*",
    "ext-curl": "*",
    "ycdev/paper-size": "^0.2.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "autoload": {
    "psr-4": {
      "Ycdev\\OsmStaticAero\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ycdev\\OsmStaticAero\\Tests\\": "tests/"
    }
  }
}
